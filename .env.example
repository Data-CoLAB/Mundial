# ── Client config (PUBLIC — ships in the browser bundle) ──
# In Vercel set these for Production + Preview. Safe to expose.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Server only (SECRET — used by /api functions, NEVER exposed to the client) ──
# Paste the ENTIRE JSON of a Firebase service-account key
# (Firebase Console → Project Settings → Service accounts → Generate new private key).
# In Vercel set this as a normal env var, NOT prefixed with VITE_.
FIREBASE_SERVICE_ACCOUNT=
